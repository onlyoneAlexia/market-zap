    },
    {
      "id": "pub-api-label", "type": "text", "x": 50, "y": 150, "width": 360, "height": 120,
      "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100,
      "groupIds": [], "frameId": null, "index": "c1", "roundness": null,
      "seed": 13, "version": 1, "versionNonce": 14, "isDeleted": false,
      "boundElements": null, "updated": 1706659200000, "link": null, "locked": false,
      "text": "API Layer (No Auth Required)\n\nGET /orderbook  -> Full bid/ask levels\nGET /trades     -> Full trade history\nGET /price      -> CLOB midpoint + AMM\nGET /quote      -> CLOB + AMM fill breakdown\nWS price        -> bestBid, bestAsk, spread\nWS trades       -> maker, taker, price, amount", "fontSize": 12, "fontFamily": 5,
      "textAlign": "left", "verticalAlign": "top", "angle": 0
    },
    {
      "id": "dark-api", "type": "rectangle", "x": 540, "y": 140, "width": 380, "height": 140,
      "strokeColor": "#1e1e1e", "backgroundColor": "#f8f0fc", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100,
      "groupIds": [], "frameId": null, "index": "c2", "roundness": {"type":3},
      "seed": 15, "version": 1, "versionNonce": 16, "isDeleted": false,
      "boundElements": null, "updated": 1706659200000, "link": null, "locked": false, "angle": 0
    },
    {
      "id": "dark-api-label", "type": "text", "x": 550, "y": 150, "width": 360, "height": 120,
      "strokeColor": "#862e9c", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100,
      "groupIds": [], "frameId": null, "index": "c3", "roundness": null,
      "seed": 17, "version": 1, "versionNonce": 18, "isDeleted": false,
      "boundElements": null, "updated": 1706659200000, "link": null, "locked": false,
      "text": "API Layer (Auth-Gated for user endpoints)\n\nGET /orderbook  -> { redacted: true, bids:[], asks:[] }\nGET /trades     -> { redacted: true } (volume only)\nGET /price      -> AMM-only pricing (no CLOB)\nGET /quote      -> AMM-only quote (no clobAvailable)\nWS price        -> lastPrice only (no bid/ask)\nWS trades       -> volume + timestamp (no addresses)", "fontSize": 12, "fontFamily": 5,
      "textAlign": "left", "verticalAlign": "top", "angle": 0
    },
    {
      "id": "pub-settle", "type": "rectangle", "x": 40, "y": 300, "width": 380, "height": 100,
      "strokeColor": "#1e1e1e", "backgroundColor": "#e7f5ff", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100,
      "groupIds": [], "frameId": null, "index": "d0", "roundness": {"type":3},
      "seed": 19, "version": 1, "versionNonce": 20, "isDeleted": false,
      "boundElements": null, "updated": 1706659200000, "link": null, "locked": false, "angle": 0
    },
    {
      "id": "pub-settle-label", "type": "text", "x": 50, "y": 310, "width": 360, "height": 80,
      "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100,
      "groupIds": [], "frameId": null, "index": "d1", "roundness": null,
      "seed": 21, "version": 1, "versionNonce": 22, "isDeleted": false,
      "boundElements": null, "updated": 1706659200000, "link": null, "locked": false,
      "text": "On-Chain Settlement: settle_trade()\n\nCalldata: 2 full Order structs + 4 sig felts\nEvent: TradeSettled { maker, taker, price, amount,\n         market_id, token_id, maker_is_buy }\nLeaderboard: Included", "fontSize": 12, "fontFamily": 5,
      "textAlign": "left", "verticalAlign": "top", "angle": 0
    },
    {
      "id": "dark-settle", "type": "rectangle", "x": 540, "y": 300, "width": 380, "height": 100,
