      "groupIds": [], "frameId": null, "index": "d2", "roundness": {"type":3},
      "seed": 23, "version": 1, "versionNonce": 24, "isDeleted": false,
      "boundElements": null, "updated": 1706659200000, "link": null, "locked": false, "angle": 0
    },
    {
      "id": "dark-settle-label", "type": "text", "x": 550, "y": 310, "width": 360, "height": 80,
      "strokeColor": "#862e9c", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100,
      "groupIds": [], "frameId": null, "index": "d3", "roundness": null,
      "seed": 25, "version": 1, "versionNonce": 26, "isDeleted": false,
      "boundElements": null, "updated": 1706659200000, "link": null, "locked": false,
      "text": "On-Chain Settlement: settle_dark_trade()\n\nCalldata: Minimal (no full orders, no sigs)\nEvent: DarkTradeSettled { market_id,\n         trade_commitment, fill_amount }\nLeaderboard: Excluded", "fontSize": 12, "fontFamily": 5,
      "textAlign": "left", "verticalAlign": "top", "angle": 0
    },
