PORT=3001
DATABASE_URL=postgresql://localhost:5432/market_zap
REDIS_URL=redis://localhost:6379
STARKNET_RPC_URL=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_8/demo
ADMIN_ADDRESS=

# --- Private key: use a keystore (recommended) or plaintext (legacy) ---
# Recommended: encrypted keystore created via `node scripts/keystore.mjs create`
ADMIN_KEYSTORE_PATH=../admin.keystore.json
ADMIN_KEYSTORE_PASSWORD=
# Legacy (NOT recommended): plaintext private key
# ADMIN_PRIVATE_KEY=

# Optional — defaults from @market-zap/shared addresses JSON.
# Only set to override (e.g. staging/test deployment).
# STARKNET_NETWORK=sepolia
# EXCHANGE_ADDRESS=
# CONDITIONAL_TOKENS_ADDRESS=
# MARKET_FACTORY_ADDRESS=
# RESOLVER_ADDRESS=
# Required in production. Protects /api/admin/* endpoints. Generate: openssl rand -hex 32
ENGINE_API_KEY=
