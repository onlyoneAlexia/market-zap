# ── MarketZap Production Environment ────────────────────────────────
# Copy this file to .env in the deploy/ directory before running docker-compose.
#
#   cp .env.production.example .env
#   nano .env   # fill in values
#   docker compose -f docker-compose.prod.yml up -d

# ── Postgres ────────────────────────────────────────────────────────
POSTGRES_PASSWORD=                      # openssl rand -base64 24

# ── Starknet ────────────────────────────────────────────────────────
STARKNET_RPC_URL=                       # e.g. https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_8/<key>
ADMIN_ADDRESS=                          # operator wallet address (0x...)
ADMIN_PRIVATE_KEY=                      # operator private key (0x...) — use keystore in mainnet!

# ── Engine Auth ─────────────────────────────────────────────────────
ENGINE_API_KEY=                         # openssl rand -hex 32

# ── Optional Overrides ──────────────────────────────────────────────
# SKIP_BALANCE_CHECK=true               # set true for testnet only
# EXCHANGE_ADDRESS=0x...                # override deployed address
# CONDITIONAL_TOKENS_ADDRESS=0x...
# MARKET_FACTORY_ADDRESS=0x...
# RESOLVER_ADDRESS=0x...
